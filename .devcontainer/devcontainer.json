{
    "name": "React Dashboard Frontend",
    "image": "mcr.microsoft.com/devcontainers/typescript-node",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "configureZshAsDefaultShell": true
        },
        "ghcr.io/devcontainers/features/docker-in-docker:4": {
            "moby": false
        },
        "ghcr.io/stu-bell/devcontainer-features/claude-code:0": {},
        "ghcr.io/w3cj/devcontainer-features/firewall:latest": {
            "githubIps": true,
            "claudeCode": true
        }
    },
    "workspaceFolder": "/workspaces/react-dashboard-fs/frontend",
    "forwardPorts": [
        5173
    ],
    "portsAttributes": {
        "5173": {
            "label": "Vite Dev Server",
            "onAutoForward": "notify"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "anthropic.claude-code"
            ],
            "settings": {
                "editor.formatOnSave": true
            }
        }
    },
    "remoteUser": "node",
    "initializeCommand": "docker network create dev-bridge-network 2>/dev/null || true",
    "runArgs": [
        "--network=dev-bridge-network"
    ],
    "postCreateCommand": "pnpm install",
    "postAttachCommand": "pnpm run dev -- --host"
}